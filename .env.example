# Server-only TMDB credentials. Never expose as NEXT_PUBLIC_.
# TMDB_ACCESS_TOKEN may contain either a TMDB read-access bearer token or a TMDB v3 API key.
# TMDB_API_KEY is an optional alternate env name for TMDB's v3 API-key auth mode.
TMDB_ACCESS_TOKEN=replace-with-server-only-tmdb-credential
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
